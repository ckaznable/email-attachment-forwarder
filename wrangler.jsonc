{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "email-attachment-forwarder",
  "main": "./src/index.ts",
  "compatibility_date": "2025-03-24",
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  }
}
